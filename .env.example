APP_NAME="InnovaCrown"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/InnovaCrown/public

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
